# ─── OpenShopFloor Environment Configuration ─────────────────────────────────
# Copy to .env and adjust values for your deployment.
# Sensitive values marked CHANGE_ME must be replaced before use.

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_PASSWORD=CHANGE_ME
# Or provide full connection string (overrides DB_HOST/DB_PORT):
# DATABASE_URL=postgresql://osf_admin:CHANGE_ME@localhost:5432/osf

# ─── MQTT Broker ──────────────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883

# ─── LLM Server (vLLM / OpenAI-compatible) ───────────────────────────────────
LLM_URL_FREE=http://localhost:5002
LLM_URL_PREMIUM=http://localhost:5001
LLM_MODEL_FREE=qwen2.5-14b-instruct
LLM_MODEL_PREMIUM=qwen2.5-32b-instruct

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# ─── Admin Seed (first startup only, when users table is empty) ───────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME

# ─── MCP Servers ──────────────────────────────────────────────────────────────
# All default to localhost. Override per server or point all to one instance.
MCP_URL=http://localhost:8020
# MCP_ERP_URL=http://localhost:8020
# MCP_OEE_URL=http://localhost:8020
# MCP_QMS_URL=http://localhost:8020
# MCP_TMS_URL=http://localhost:8020
# MCP_UNS_URL=http://localhost:8025
# MCP_KG_URL=http://localhost:8020

# ─── KG Agent (Apache AGE) ───────────────────────────────────────────────────
ERP_DB_HOST=localhost
ERP_DB_PORT=5432
ERP_DB_NAME=erpdb
ERP_DB_USER=admin
ERP_DB_PASSWORD=CHANGE_ME

# ─── Historian ────────────────────────────────────────────────────────────────
HISTORIAN_DB_HOST=localhost
HISTORIAN_DB_PORT=5432
HISTORIAN_DB_NAME=bigdata_homelab
HISTORIAN_DB_USER=admin
HISTORIAN_DB_PASSWORD=CHANGE_ME

# ─── Gateway ──────────────────────────────────────────────────────────────────
PORT=8012
NODE_ENV=production
# CORS_ORIGINS=https://your-frontend.example.com

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://osf-api.zeroguess.ai

# ─── Optional: Node-RED ──────────────────────────────────────────────────────
# NR_DISABLED=true

# ─── Optional: Factory Simulator ──────────────────────────────────────────────
# FACTORY_SIM_URL=http://localhost:8888
