{
  "name": "osf-kg-builder",
  "version": "9.3.0",
  "description": "OSF KG Platform — Builder (batch) + Server (always-on MCP, REST, MQTT)",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "swc src -d dist --source-maps --copy-files --strip-leading-paths",
    "build-kg": "tsx src/builder/index.ts",
    "serve": "tsx src/server/index.ts",
    "dev": "tsx src/server/index.ts",
    "verify": "tsx src/builder/verify.ts",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "fast-xml-parser": "^4.5.0",
    "mqtt": "^5.15.0",
    "neo4j-driver": "^6.0.1",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
