# ── v9 KG Platform — Environment Configuration ──────────────────────
# Copy to .env and adjust values for your environment.

# ── Server ──────────────────────────────────────────────────────────
PORT=8035

# ── LLM (llama.cpp, OpenAI-compatible API on .120) ────────────────
# Port 5001 = Qwen2.5-32B Q4_K_M (premium, schema planning, synthesis)
# Port 5002 = Qwen2.5-14B Q4_K_M (fast, specialist tasks)
LLM_URL=http://llm:5001
LLM_MODEL=qwen2.5-32b-instruct
LLM_MAX_TOKENS=4096
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=120000

# ── Chart Engine (optional: use 14B for faster chart generation) ──
CHART_LLM_MODEL=

# ── MCP Proxy ──────────────────────────────────────────────────────
MCP_PROXY_URL=http://osf-mcp-proxy:8034

# ── PostgreSQL (only for kg_builder_runs table) ────────────────────
ERP_DB_HOST=postgres
ERP_DB_PORT=5432
ERP_DB_NAME=erpdb
ERP_DB_USER=admin
ERP_DB_PASSWORD=changeme
DB_SCHEMA=llm_test_v3

# ── Neo4j (Knowledge Graph) ───────────────────────────────────────
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# ── Embeddings (dedicated nomic-embed-text via llama.cpp) ─────────
# Port 5003 = nomic-embed-text GGUF — 768d, CPU-only, 137MB
# Start: llama-server -m nomic-embed-text.gguf --port 5003 --embedding
EMBEDDING_URL=http://llm:5003
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# ── MQTT (single raw broker — no second broker needed) ────────────
MQTT_RAW_URL=mqtt://mqtt-raw:1883
# JSON array of transform rules (optional — defaults to Factory/#)
MQTT_TRANSFORM_RULES=

# ── Gateway Integration (optional — leave empty for standalone) ───
# KG-Server auto-registers in Gateway's mcp_servers table at startup.
# Gateway discovers tools via tools/list within 60s.
GATEWAY_DB_URL=
KG_SERVER_URL=http://kg-server:8035

# ── Domain & Data Sources ─────────────────────────────────────────
# Template-based: discrete, process, pharma, automotive
# Custom: set DOMAIN_CONFIG_PATH to a JSON file
DOMAIN=discrete
DOMAIN_CONFIG_PATH=
SM_PROFILE_URL=
MTP_URLS=
I3X_ENDPOINTS=
