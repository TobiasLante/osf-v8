# ── v9 KG Builder — Environment Configuration ──────────────────────
# Copy to .env and adjust values for your environment.

# ── Server ──────────────────────────────────────────────────────────
PORT=8035

# ── LLM (llama.cpp, OpenAI-compatible API on .120) ────────────────
# Port 5001 = Qwen2.5-32B Q4_K_M (premium, schema planning, synthesis)
# Port 5002 = Qwen2.5-14B Q4_K_M (fast, specialist tasks)
LLM_URL=http://llm:5001
LLM_MODEL=qwen2.5-32b-instruct
LLM_MAX_TOKENS=4096
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=120000

# ── Chart Engine (optional: use 14B for faster chart generation) ──
CHART_LLM_MODEL=

# ── MCP Proxy ──────────────────────────────────────────────────────
MCP_PROXY_URL=http://osf-mcp-proxy:8034

# ── PostgreSQL (only for kg_builder_runs table) ────────────────────
ERP_DB_HOST=postgres
ERP_DB_PORT=5432
ERP_DB_NAME=erpdb
ERP_DB_USER=admin
ERP_DB_PASSWORD=changeme
DB_SCHEMA=llm_test_v3

# ── Neo4j (Knowledge Graph) ───────────────────────────────────────
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# ── Embeddings (llama.cpp /v1/embeddings on .120) ────────────────
# Port 5002 = Qwen2.5-14B — supports OpenAI-compatible /v1/embeddings
EMBEDDING_URL=http://llm:5002
EMBEDDING_MODEL=qwen2.5-14b-instruct
EMBEDDING_DIM=384

# ── MQTT Dual-Broker ──────────────────────────────────────────────
MQTT_RAW_URL=mqtt://mqtt-raw:1883
MQTT_CURATED_URL=mqtt://mqtt-curated:1883
# JSON array of transform rules (optional — defaults to Factory/#)
MQTT_TRANSFORM_RULES=

# ── Domain & Data Sources ─────────────────────────────────────────
DOMAIN=manufacturing
DOMAIN_CONFIG_PATH=
SM_PROFILE_URL=
MTP_URLS=
I3X_ENDPOINTS=
