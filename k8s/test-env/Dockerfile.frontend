# OSF Frontend — Test build with configurable API URL
FROM node:20-alpine AS build

WORKDIR /app

ARG NEXT_PUBLIC_API_URL=http://192.168.178.110:8012

COPY package.json package-lock.json ./
RUN npm ci

COPY src/ ./src/
COPY public/ ./public/
COPY next.config.mjs tailwind.config.ts postcss.config.mjs tsconfig.json ./

# Write .env with the test API URL (overrides any checked-in .env)
RUN printf "NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}\nNEXT_PUBLIC_APP_VERSION=9.0.0-test\n" > .env

RUN npm run build

# ─── Serve stage ──────────────────────────────────────────────────────────
FROM nginx:alpine

COPY --from=build /app/out/ /usr/share/nginx/html/

RUN printf 'server {\n  listen 3000;\n  root /usr/share/nginx/html;\n  index index.html;\n  location / {\n    try_files $uri $uri.html $uri/ /index.html;\n  }\n}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
