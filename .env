# ════════════════════════════════════════════════════════════════
# OSF — Zentrale Versionsverwaltung
# Wird von k8s/deploy-and-test.sh und K8s Manifests gelesen
# ════════════════════════════════════════════════════════════════

# ── Backend (alle gleiche Version) ─────────────────────────────
OSF_BACKEND_VERSION=8.9.0

# ── Component versions (Backend = OSF_BACKEND_VERSION) ─────────
OSF_GATEWAY_VERSION=${OSF_BACKEND_VERSION}
OSF_KG_SERVER_VERSION=${OSF_BACKEND_VERSION}
OSF_KG_BUILDER_VERSION=${OSF_BACKEND_VERSION}
OSF_HISTORIAN_VERSION=${OSF_BACKEND_VERSION}

# ── Frontend + Sim (eigene Versionen) ──────────────────────────
OSF_FRONTEND_VERSION=1.19.0
OSF_V9_WEB_VERSION=1.1.0
OSF_CHAT_UI_VERSION=8.2.2
OSF_NODERED_VERSION=latest
FACTORY_SIM_VERSION=3.2.0

# ── Registry ───────────────────────────────────────────────────
OSF_REGISTRY=192.168.178.150:32000

# ── Infrastructure IPs ─────────────────────────────────────────
OSF_NODE=192.168.178.150
LLM_NODE=192.168.178.120

# ── Infrastructure Ports (NodePorts) ───────────────────────────
MQTT_NODEPORT=31883
PG_NODEPORT=30432
ERP_DB_NODEPORT=30431
FACTORY_NODEPORT=30888
GATEWAY_NODEPORT=30880
KG_SERVER_NODEPORT=30035
V9_WEB_NODEPORT=30909
EMBEDDING_PORT=5003
