{
  "name": "pharma-chat-ui",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @p1/gateway dev\" \"pnpm --filter @p1/web dev\"",
    "dev:web": "pnpm --filter @p1/web dev",
    "dev:gateway": "pnpm --filter @p1/gateway dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @p1/web build",
    "build:gateway": "pnpm --filter @p1/gateway build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
