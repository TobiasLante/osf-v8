FROM node:20-alpine AS builder
WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy workspace config + lockfile
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/gateway/package.json packages/gateway/

# Install deps
RUN pnpm install --frozen-lockfile

# Copy source
COPY packages/shared/ packages/shared/
COPY packages/gateway/ packages/gateway/

# Copy Vendor Map data (needed at runtime by site-intelligence)
COPY vendor-map.xlsx /data/vendor-map.xlsx

# Build
RUN cd packages/gateway && pnpm build

# ── Production ──
FROM node:20-alpine
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY --from=builder /app/pnpm-workspace.yaml /app/pnpm-lock.yaml /app/package.json ./
COPY --from=builder /app/packages/shared/ packages/shared/
COPY --from=builder /app/packages/gateway/package.json packages/gateway/
COPY --from=builder /app/packages/gateway/dist/ packages/gateway/dist/
COPY --from=builder /data/vendor-map.xlsx /data/vendor-map.xlsx

RUN pnpm install --frozen-lockfile --prod

ENV PORT=3101
ENV VENDOR_MAP_PATH=/data/vendor-map.xlsx
EXPOSE 3101

CMD ["node", "packages/gateway/dist/index.js"]
